{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    "boost-asio",
    "boost-iostreams",
    "boost-lockfree",
    "boost-system",
    "boost-variant",
    "cryptopp",
    "fmt",
    "libmariadb",
    "pugixml"
  ],
  "features": {
    "lua": {
      "description": "Use Lua instead of LuaJIT",
      "dependencies": [
        "lua"
      ]
    },
    "luajit": {
      "description": "Use LuaJIT instead of Lua",
      "dependencies": [
        "luajit"
      ]
    },
    "tests": {
      "description": "Install dependencies required to run tests",
      "dependencies": [
        "boost-test"
      ]
    }
  },
  "builtin-baseline": "0fa8459cf3a7caca7adc58f992bc32ff13630684"
}
